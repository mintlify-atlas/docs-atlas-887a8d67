  "keyFeatures": [
    "Translates entire Git repositories between 6 languages: Python, Java, JavaScript, TypeScript, C#, PHP",
    "LangGraph multi-agent orchestration with 4 specialized agents: Analysis, Planning, Translation, Validation",
    "RAG system using Qdrant vector database for pattern-based context-aware translation",
    "Claude Sonnet AI for intelligent, idiom-preserving code translation",
    "4 translation strategies: Direct, Pattern, Refactor, Hybrid — automatically selected by complexity",
    "AST analysis with Tree-sitter for deep code structure understanding",
    "Human-in-the-loop (HITL) support for manual review of critical translations",
    "Retry mechanism with exponential backoff and fallback translation",
    "Quality scoring and validation with confidence metrics",
    "Streaming CLI progress tracking with Rich terminal UI"
  ],
  "publicApiSurface": [
